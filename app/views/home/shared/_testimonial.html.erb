<div class="space-y-6">
  <div class="bg-white dark:bg-dark-gray border border-dark-gray/50 dark:border-white/35 rounded-3xl px-8 py-4 relative rounded-tl-3xl rounded-tr-3xl rounded-br-3xl rounded-bl-sm">
    <div class="mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="currentColor" class="w-5 h-3" aria-hidden="true"><path d="m21.01,10h-2.85c.27-1.02,1.01-2.51,3.09-3.03l.76-.19v-2.78h-1c-2.78,0-4.91.77-6.31,2.29-1.89,2.05-1.7,4.68-1.69,4.71v7c0,1.1.9,2,2,2h6c1.1,0,2-.9,2-2v-6c0-1.1-.9-2-2-2Z"/><path d="m9.01,10h-2.85c.27-1.02,1.01-2.51,3.09-3.03l.76-.19v-2.78h-1c-2.78,0-4.91.77-6.31,2.29-1.89,2.05-1.7,4.68-1.69,4.71v7c0,1.1.9,2,2,2h6c1.1,0,2-.9,2-2v-6c0-1.1-.9-2-2-2Z"/></svg>
    </div>
    <p class="text-black dark:text-white text-xl leading-relaxed font-medium">
      <%= quote %>
    </p>
  </div>
  <div class="flex items-center gap-4 pl-2">
    <div class="rounded-full p-1">
      <div class="w-12 h-12 rounded-full bg-white flex items-center justify-center overflow-hidden">
        <%= image_tag avatar_path, alt: name, class: "w-full h-full object-cover rounded-full" %>
      </div>
    </div>
    <div>
      <h3 class="font-bold text-black dark:text-white text-lg"><%= name %></h3>
      <p class="text-black dark:text-white/70 text-sm"><%= description %></p>
    </div>
  </div>
</div>
