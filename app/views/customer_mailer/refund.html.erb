<%= header_section("You have been refunded.") %>
<div>
  <% if @formatted_presentment_total.present? %>
    <%# Presentment purchases were charged in the buyer's own currency, so lead with the
        full purchase total in that currency (it matches their card statement) and show
        the canonical USD total alongside. %>
    <p>Your purchase of <%= @purchase.link_name %> for <%= @formatted_presentment_total %> (<%= @formatted_usd_total %> USD) on Gumroad has been fully refunded. It may take up to 3-7 days to show up in your account.</p>
  <% else %>
    <p>Your purchase of <%= @purchase.link_name %> for <%= @purchase.formatted_total_transaction_amount %> on Gumroad has been fully refunded. It may take up to 3-7 days to show up in your account.</p>
  <% end %>
</div>
