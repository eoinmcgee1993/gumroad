<%= render("shared/preheader_text", text: @installment.truncated_description) %>
<%= header_section(post_title_displayable(post: @installment)) %>
<%# dir="auto" lets email clients pick text direction per paragraph from the first strong
    character, so Hebrew/Arabic emails read right-to-left while Latin-script content is
    unaffected (gumroad-private#1244). %>
<div class="rich-text" dir="auto">
  <%= raw Rinku.auto_link(@installment.message_with_inline_syntax_highlighting_and_upsells&.html_safe, :all, 'target="_blank" rel="nofollow"') %>
</div>
